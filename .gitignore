.zig-cache/
zig-out/
zig-pkg/
.DS_Store

# Generated tiles (regenerate with `vantage mesh` / `meshtex` → web/public/)
*.vtile
*.vtexarr
# … except the small gzip-wrapped golden fixtures the web tests decode
# (produced by the real Zig generator; see web/test/golden.test.ts).
!web/test/fixtures/*.vtile
!web/test/fixtures/*.vtexarr

# Web package (see web/.gitignore for the rest)
web/node_modules/
web/dist/
web/dist-demo/
web/dist-viewer/

# Tauri desktop app
desktop/node_modules/
desktop/dist/
desktop/src-tauri/target/
desktop/src-tauri/binaries/*.exe
desktop/src-tauri/gen/
desktop/src-tauri/icons/android/
desktop/src-tauri/icons/ios/
desktop/src-tauri/icons/Square*Logo.png
desktop/src-tauri/icons/StoreLogo.png

# Local developer bootstrap markers
**/node_modules/.vantage-lock
.vantage-dev/

# Tiled render output (regenerate with `vantage render`)
web/public/manifest.json
web/public/tiles/
