{
  "name": "@thoughts-on-things/vantage-mc",
  "version": "0.5.0",
  "description": "Render a Minecraft (Java) world as a fast, beautiful 3D web map. The web frontend for the Vantage generator.",
  "type": "module",
  "license": "MIT",
  "author": "Luis Padron",
  "homepage": "https://github.com/thoughts-on-things/vantage-mc#readme",
  "bugs": "https://github.com/thoughts-on-things/vantage-mc/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/thoughts-on-things/vantage-mc.git",
    "directory": "web"
  },
  "keywords": [
    "minecraft",
    "map",
    "renderer",
    "three.js",
    "webgl",
    "react",
    "vantage"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "types": "./dist/three/index.d.ts",
  "module": "./dist/three/index.js",
  "exports": {
    ".": {
      "types": "./dist/three/index.d.ts",
      "import": "./dist/three/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./three": {
      "types": "./dist/three/index.d.ts",
      "import": "./dist/three/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsup",
    "build:demo": "vite build",
    "build:viewer": "vite build -c vite.viewer.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run typecheck && npm run test && npm run build",
    "prepublishOnly": "npm run ci"
  },
  "overrides": {
    "tsup": {
      "esbuild": "^0.28.1"
    }
  },
  "allowScripts": {
    "esbuild": true
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.160"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.185.1",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
